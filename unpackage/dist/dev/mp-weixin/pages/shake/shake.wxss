/* 3D：摇卦时绕 Y 轴连续翻面 + 绕 Z 旋转，模拟钱币在空中翻滚 */
.coin-scene.data-v-ec565d25 {
	width: 200rpx;
	height: 200rpx;
	perspective: 520rpx;
	perspective-origin: 50% 45%;
}
.coin-axis.data-v-ec565d25 {
	width: 100%;
	height: 100%;
	position: relative;
	transform-style: preserve-3d;
	box-shadow: 0 14rpx 34rpx rgba(40, 30, 20, 0.12);
	border-radius: 50%;
}
.coin-axis--run.data-v-ec565d25 {
	animation: coinRumbleFlip-ec565d25 0.82s ease-in-out forwards;
}
.coin-side.data-v-ec565d25 {
	position: absolute;
	left: 0;
	top: 0;
	width: 100%;
	height: 100%;
	border-radius: 50%;
	overflow: hidden;
	-webkit-backface-visibility: hidden;
	        backface-visibility: hidden;
	border: 6rpx solid rgba(107, 78, 46, 0.35);
	box-sizing: border-box;
	background: #efe6d8;
}
.coin-side--yang.data-v-ec565d25 {
	transform: translateZ(2rpx);
}
.coin-side--yin.data-v-ec565d25 {
	transform: rotateY(180deg) translateZ(2rpx);
}
.coin__bg.data-v-ec565d25 {
	width: 100%;
	height: 100%;
}
.coin__mask.data-v-ec565d25 {
	position: absolute;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.22), transparent 55%);
}
.coin__label.data-v-ec565d25 {
	min-width: 72rpx;
	text-align: center;
	padding: 6rpx 14rpx;
	border-radius: 999rpx;
	font-size: 28rpx;
	font-weight: 900;

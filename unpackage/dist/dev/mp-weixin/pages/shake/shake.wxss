	background: rgba(107, 78, 46, 0.12);
	border: 1rpx solid rgba(107, 78, 46, 0.22);
}
.coin__label--yin.data-v-ec565d25 {
	color: #4a4036;
	background: rgba(60, 60, 60, 0.08);
	border: 1rpx solid rgba(60, 60, 60, 0.14);
}
.coin__label--busy.data-v-ec565d25 {
